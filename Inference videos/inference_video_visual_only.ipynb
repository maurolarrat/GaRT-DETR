import torch
import cv2
import numpy as np
import torch.nn.functional as F
from torchvision import transforms
from tqdm import tqdm
import os

from SuperiorDETR import SuperiorDETR

# ============================================================
# CLASSE DE ABLAÇÃO (DEFINIDA AQUI PARA EVITAR ModuleNotFoundError)
# ============================================================
class AblationModelWrapper(torch.nn.Module):
    def __init__(self, model, mode="dual", device="cuda"):
        super().__init__()
        self.model = model
        self.mode = mode
        self.device = device
        # Estatísticas para re-normalização interna (essencial para o espelhamento matemático)
        self.vis_mean = torch.tensor([0.485, 0.456, 0.406]).view(3, 1, 1).to(device)
        self.vis_std = torch.tensor([0.229, 0.224, 0.225]).view(3, 1, 1).to(device)
        self.ir_mean = torch.tensor([0.449]).view(1, 1, 1).to(device)
        self.ir_std = torch.tensor([0.226]).view(1, 1, 1).to(device)

    def forward(self, vis_frames, ir_frames):
        # Se falha o RGB, criamos Pseudo-RGB a partir do IR [I, Gx, Gy]
        if self.mode == "ir_only":
            new_vis_frames = []
            for seq in ir_frames:
                new_seq = []
                for frame in seq:
                    # Simulação de gradientes conforme seu protocolo
                    grad_x = torch.abs(frame[:, :, 1:] - frame[:, :, :-1])
                    grad_x = F.pad(grad_x, (0, 1, 0, 0))
                    grad_y = torch.abs(frame[:, 1:, :] - frame[:, :-1, :])
                    grad_y = F.pad(grad_y, (0, 0, 0, 1))
                    pseudo_rgb = torch.cat([frame, grad_x, grad_y], dim=0)
                    new_seq.append(pseudo_rgb)
                new_vis_frames.append(new_seq)
            vis_frames = new_vis_frames

        # Se falha o IR, criamos Pseudo-IR a partir do RGB (Saliência + Blur)
        elif self.mode == "visible_only":
            new_ir_frames = []
            for seq in vis_frames:
                new_seq = []
                for frame in seq:
                    frame_raw = frame * self.vis_std + self.vis_mean
                    thermal_sim, _ = torch.max(frame_raw, dim=0, keepdim=True)
                    thermal_sim = transforms.functional.gaussian_blur(thermal_sim, [5, 5], sigma=1.0)
                    thermal_sim = (thermal_sim - thermal_sim.min()) / (thermal_sim.max() - thermal_sim.min() + 1e-6)
                    thermal_sim = (thermal_sim - self.ir_mean) / self.ir_std
                    new_seq.append(thermal_sim)
                new_ir_frames.append(new_seq)
            ir_frames = new_ir_frames
            
        return self.model(vis_frames, ir_frames)

# ============================================================
# CONFIGURAÇÕES DE EXECUÇÃO
# ============================================================
DEVICE = torch.device("cuda" if torch.cuda.is_available() else "cpu")
CHECKPOINT_PATH = "checkpoints/superior_detr_best.pth"
VIDEO_VIS_PATH = r"C:\Users\Micro\Documents\sourcecode\Anti-UAV-RGBT\test\20190926_134054_1_1\visible.mp4"
VIDEO_IR_PATH = r"C:\Users\Micro\Documents\sourcecode\Anti-UAV-RGBT\test\20190926_134054_1_1\infrared.mp4"

# ALTERNE O MODO AQUI: "dual", "visible_only", "ir_only"
MODE = "visible_only" 
OUTPUT_PATH = f"experimento_ablativo_{MODE}.mp4"

# ============================================================
# LÓGICA DE VISUALIZAÇÃO (OPENCV)
# ============================================================
def get_pseudo_rgb_opencv(frame_i):
    """Gera visualização de gradientes a partir do IR (Grayscale)"""
    gray = cv2.cvtColor(frame_i, cv2.COLOR_BGR2GRAY) if len(frame_i.shape) == 3 else frame_i
    gx = cv2.convertScaleAbs(cv2.Sobel(gray, cv2.CV_64F, 1, 0, ksize=3))
    gy = cv2.convertScaleAbs(cv2.Sobel(gray, cv2.CV_64F, 0, 1, ksize=3))
    return cv2.merge([gray, gx, gy])

def get_pseudo_ir_opencv(frame_v):
    """Gera visualização de saliência + blur a partir do RGB"""
    rgb = cv2.cvtColor(frame_v, cv2.COLOR_BGR2RGB)
    saliency = np.max(rgb, axis=2).astype(np.uint8)
    blur = cv2.GaussianBlur(saliency, (5, 5), 1.0)
    return cv2.cvtColor(blur, cv2.COLOR_GRAY2BGR)

# ============================================================
# INICIALIZAÇÃO E LOOP
# ============================================================
base_model = SuperiorDETR(d_model=256, n_queries=20).to(DEVICE)
state_dict = torch.load(CHECKPOINT_PATH, map_location=DEVICE, weights_only=False)
base_model.load_state_dict(state_dict['model_state_dict'] if 'model_state_dict' in state_dict else state_dict)
base_model.eval()

# Encapsula o modelo com o Wrapper de Ablação
model = AblationModelWrapper(base_model, mode=MODE, device=DEVICE)

transform_vis = transforms.Compose([transforms.ToTensor(), transforms.Normalize([0.485, 0.456, 0.406], [0.229, 0.224, 0.225])])
transform_ir = transforms.Compose([transforms.ToTensor(), transforms.Normalize([0.449], [0.226])])

cap_vis = cv2.VideoCapture(VIDEO_VIS_PATH)
cap_ir = cv2.VideoCapture(VIDEO_IR_PATH)
fps = int(cap_vis.get(cv2.CAP_PROP_FPS))
w_v, h_v = int(cap_vis.get(3)), int(cap_vis.get(4))
w_i, h_i = int(cap_ir.get(3)), int(cap_ir.get(4))

out = cv2.VideoWriter(OUTPUT_PATH, cv2.VideoWriter_fourcc(*'mp4v'), fps, (w_v * 2, h_v))
pbar = tqdm(total=int(cap_vis.get(7)), desc=f"Modo: {MODE}")

while cap_vis.isOpened() and cap_ir.isOpened():
    ret_v, frame_v = cap_vis.read()
    ret_i, frame_i = cap_ir.read()
    if not ret_v or not ret_i: break

    # 1. Definir o que será exibido no vídeo (Canvas)
    if MODE == "visible_only":
        display_v = frame_v.copy()
        display_i = get_pseudo_ir_opencv(frame_v) # IR falhou, mostra o espelhamento
    elif MODE == "ir_only":
        display_v = get_pseudo_rgb_opencv(frame_i) # RGB falhou, mostra gradientes do IR
        display_i = frame_i.copy()
    else:
        display_v, display_i = frame_v.copy(), frame_i.copy()

    # 2. Preparação para o Modelo (O Wrapper cuida do espelhamento nos tensores)
    img_v_rgb = cv2.cvtColor(frame_v, cv2.COLOR_BGR2RGB)
    img_i_gray = cv2.cvtColor(frame_i, cv2.COLOR_BGR2GRAY) if len(frame_i.shape) == 3 else frame_i
    
    t_v = transform_vis(img_v_rgb).to(DEVICE)
    t_i = transform_ir(img_i_gray).to(DEVICE)

    with torch.no_grad():
        outputs = model([[t_v]], [[t_i]])
        conf_idx = torch.argmax(outputs["exist"][0, 0])
        
        def post_box(box_norm, w, h):
            cx, cy, nw, nh = box_norm
            return [int((cx-0.5*nw)*w), int((cy-0.5*nh)*h), int((cx+0.5*nw)*w), int((cy+0.5*nh)*h)]

        coords_v = post_box(outputs["pred_boxes_vis"][0, 0, conf_idx].cpu().numpy(), w_v, h_v)
        # Bbox do IR calculada sobre o tamanho atual do display IR (640x512)
        h_i_actual, w_i_actual = display_i.shape[:2]
        coords_i = post_box(outputs["pred_boxes_ir"][0, 0, conf_idx].cpu().numpy(), w_i_actual, h_i_actual)

    # 3. Desenho nas Pseudo-Imagens
    cv2.rectangle(display_v, (coords_v[0], coords_v[1]), (coords_v[2], coords_v[3]), (0, 255, 0), 2)
    if len(display_i.shape) == 2: display_i = cv2.cvtColor(display_i, cv2.COLOR_GRAY2BGR)
    cv2.rectangle(display_i, (coords_i[0], coords_i[1]), (coords_i[2], coords_i[3]), (0, 0, 255), 2)

    # Legendas para o revisor não ter dúvidas
    txt_v = "RGB (Native)" if MODE != "ir_only" else "Pseudo-RGB (IR-based)"
    txt_i = "IR (Native)" if MODE != "visible_only" else "Pseudo-IR (VIS-based)"
    cv2.putText(display_v, txt_v, (10, 40), 1, 2, (0, 255, 0), 2)
    cv2.putText(display_i, txt_i, (10, 40), 1, 2, (0, 0, 255), 2)

    # Concatenação e Redimensionamento
    ir_resized = cv2.resize(display_i, (w_v, h_v))
    combined = np.hstack((display_v, ir_resized))
    out.write(combined)
    pbar.update(1)

cap_vis.release(); cap_ir.release(); out.release(); pbar.close()
print(f"\n[+] Vídeo gerado com sucesso: {OUTPUT_PATH}")
